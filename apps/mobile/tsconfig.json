{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "types": ["react", "react-native"],
    "paths": {
      "@/*": ["./*"],
      "@domain/*": ["../../src/domain/*"],
      "@application/*": ["../../src/application/*"],
      "@infra/*": ["../../src/infrastructure/*"],
      "@ui/*": ["../../src/ui/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}